{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "stashyjd",
  "version": "0.1.16",
  "identifier": "com.stashyjd.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "stashyjd",
        "width": 800,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE5MzhENDkxQzlCN0ZEQjkKUldTNS9iZkprZFE0cVlBSjNoSlJ2VGJvQ245Zk84aEtkSEEyTkQ3aWF2a2Z3L3lRSGhzZGFTMHAK",
      "endpoints": [
        "https://github.com/flintbits/stashyjd/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
